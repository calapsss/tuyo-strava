NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Optional override. Must exactly match your Strava app callback URL setting.
# STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Payment gate
# Public path to your GCash QR image (put file inside /public)
NEXT_PUBLIC_GCASH_QR_IMAGE_PATH=/gcash-qr.png
# Optional promo end date (ISO format). If omitted, defaults to 1 month from build time.
# NEXT_PUBLIC_PROMO_END_AT=2026-04-15T00:00:00.000Z

# Discord webhook where payment screenshots are sent
DISCORD_PAYMENT_WEBHOOK_URL=your_discord_webhook_url
